{
  "initialState": "IDLE",
  "states": {

    "IDLE": {
      "defaultResponse": "Send *hi* to begin your Tranché Bakery order.",
      "transitions": [
        { "match": "hi", "ignoreCase": true, "nextState": "MAIN_MENU" }
      ]
    },

    "MAIN_MENU": {
      "entryMessage": {
        "type": "buttons",
        "body": "Welcome to Tranché Bakery. 🥖\n\nSmall-batch, European-inspired breads baked fresh for each day's orders. Orders placed before *6 PM* are usually prepared for next-day delivery.\n\nHow can we help you today?\n\n_Send *hi* anytime to return to the main menu._",
        "buttons": [
          { "id": "order",   "title": "Order" },
          { "id": "message", "title": "Message Us" },
          { "id": "hours",   "title": "Hours & Info" }
        ]
      },
      "transitions": [
        { "match": "order",   "nextState": "ORDER_SELECT_CATEGORY" },
        { "match": "message", "nextState": "MESSAGE_AWAITING_TEXT" },
        { "match": "hours",   "nextState": "HOURS_INFO" },
        { "match": "*",       "nextState": "MAIN_MENU" }
      ]
    },

    "HOURS_INFO": {
      "entryMessage": {
        "type": "text",
        "body": "*Bake Days:* Tuesday to Sunday\n*Order Cutoff:* 6 PM\n\nWe bake in small batches, closer to order, without commercial improvers or preservatives.\n\nOrders placed by *6 PM* are usually baked the next morning. Orders placed after *6 PM* are scheduled for the following bake day."
      },
      "autoTransition": "MAIN_MENU"
    },

    "AREA_SELECT": {
      "entryMessage": {
        "type": "text",
        "body": "Hello. We currently deliver to select areas in Gurgaon.\n\nPlease share your *pincode* so we can confirm delivery availability:"
      },
      "transitions": [
        { "match": "*", "nextState": "NAME_COLLECT", "saveContext": "pincode", "action": "SAVE_AREA" }
      ]
    },

    "NAME_COLLECT": {
      "entryMessage": {
        "type": "text",
        "body": "Good news — we deliver to your area.\n\nMay we have your name for the order?"
      },
      "transitions": [
        { "match": "*", "nextState": "MAIN_MENU", "saveContext": "customerName", "action": "SAVE_NAME" }
      ]
    },

    "ORDER_SELECT_CATEGORY": {
      "entryMessage": {
        "type": "list",
        "body": "Please choose a category to begin your order:",
        "buttonLabel": "View Categories",
        "dataSource": "MENU_CATEGORIES"
      },
      "transitions": [
        { "match": "*", "nextState": "ORDER_SELECT_ITEM", "saveContext": "categoryId" }
      ]
    },

    "ORDER_SELECT_ITEM": {
      "entryMessage": {
        "type": "list",
        "body": "Please select an item from this category:",
        "buttonLabel": "View Items",
        "dataSource": "MENU_ITEMS"
      },
      "transitions": [
        { "match": "*", "nextState": "ORDER_SELECT_QUANTITY", "saveContext": "itemId" }
      ]
    },

    "ORDER_SELECT_QUANTITY": {
      "entryMessage": {
        "type": "buttons",
        "body": "How many would you like? Tap a button, or type *4* or *5* for a larger quantity:",
        "buttons": [
          { "id": "1", "title": "1" },
          { "id": "2", "title": "2" },
          { "id": "3", "title": "3" }
        ]
      },
      "transitions": [
        { "match": "1", "nextState": "ORDER_ADD_MORE", "saveContext": "quantity", "action": "ADD_ITEM_TO_ORDER" },
        { "match": "2", "nextState": "ORDER_ADD_MORE", "saveContext": "quantity", "action": "ADD_ITEM_TO_ORDER" },
        { "match": "3", "nextState": "ORDER_ADD_MORE", "saveContext": "quantity", "action": "ADD_ITEM_TO_ORDER" },
        { "match": "4", "nextState": "ORDER_ADD_MORE", "saveContext": "quantity", "action": "ADD_ITEM_TO_ORDER" },
        { "match": "5", "nextState": "ORDER_ADD_MORE", "saveContext": "quantity", "action": "ADD_ITEM_TO_ORDER" },
        { "match": "*", "errorMessage": "We can do between 1 and 5 per item. Please tap a button or type a number." }
      ]
    },

    "ORDER_ADD_MORE": {
      "entryMessage": {
        "type": "buttons",
        "body": "Added to your order.\n\nWould you like to add anything else, or review your order?",
        "buttons": [
          { "id": "add_item",   "title": "Add Another" },
          { "id": "view_order", "title": "View Order" }
        ]
      },
      "transitions": [
        { "match": "add_item",   "nextState": "ORDER_SELECT_CATEGORY" },
        { "match": "view_order", "nextState": "ADDRESS_GATE" },
        { "match": "*",          "nextState": "ORDER_ADD_MORE" }
      ]
    },

    "ADDRESS_GATE": {
      "entryAction": "ROUTE_TO_ADDRESS_OR_CONFIRM"
    },

    "ADDRESS_COLLECT": {
      "entryMessage": {
        "type": "text",
        "body": "Please share your full delivery address:\n\n_Example: Flat 4B, Tower 2, Emerald Hills, DLF Phase 5_\n\n_We'll save this address for future orders. You can change it anytime._"
      },
      "transitions": [
        { "match": "*", "nextState": "LOCATION_SHARE", "saveContext": "deliveryAddress", "action": "SAVE_DELIVERY_ADDRESS" }
      ]
    },

    "ADDRESS_CONFIRM": {
      "entryAction": "SHOW_SAVED_ADDRESS",
      "transitions": [
        { "match": "use_address",    "nextState": "ORDER_CONFIRM",        "action": "COPY_ADDRESS_TO_ORDER" },
        { "match": "change_address", "nextState": "ADDRESS_COLLECT_TEMP"  },
        { "match": "*",              "nextState": "ADDRESS_CONFIRM"        }
      ]
    },

    "ADDRESS_COLLECT_TEMP": {
      "entryMessage": {
        "type": "text",
        "body": "Please share the delivery address for this order:\n\n_Example: Flat 4B, Tower 2, Emerald Hills, DLF Phase 5_"
      },
      "transitions": [
        { "match": "*", "nextState": "LOCATION_SHARE_TEMP", "saveContext": "deliveryAddress", "action": "SAVE_DELIVERY_ADDRESS_TEMP" }
      ]
    },

    "LOCATION_SHARE": {
      "entryMessage": {
        "type": "text",
        "body": "Almost done — please share a pinned location so our delivery team can find you easily.\n\nTap the paperclip icon → *Location* → send a *pinned location*.\n\nPlease avoid live location."
      },
      "transitions": [
        { "matchType": "location", "nextState": "ORDER_CONFIRM", "action": "SAVE_LOCATION" }
      ]
    },

    "LOCATION_SHARE_TEMP": {
      "entryMessage": {
        "type": "text",
        "body": "Almost done — please share a pinned location for this delivery address.\n\nTap the paperclip icon → *Location* → send a *pinned location*.\n\nPlease avoid live location."
      },
      "transitions": [
        { "matchType": "location", "nextState": "ORDER_CONFIRM", "action": "SAVE_LOCATION_TEMP" }
      ]
    },

    "ORDER_CONFIRM": {
      "entryAction": "SHOW_ORDER_SUMMARY",
      "transitions": [
        { "match": "confirm", "nextState": "PAYMENT_PENDING", "action": "CONFIRM_ORDER" },
        { "match": "cancel",  "nextState": "MAIN_MENU",       "action": "CANCEL_ORDER"  }
      ]
    },

    "PAYMENT_PENDING": {
      "entryAction": "SEND_PAYMENT_QR",
      "transitions": [
        { "matchType": "image", "nextState": "PAYMENT_RECEIVED", "action": "SAVE_PAYMENT_SCREENSHOT" },
        { "match": "cancel_order", "nextState": "MAIN_MENU", "action": "CANCEL_ORDER" }
      ]
    },

    "PAYMENT_RECEIVED": {
      "entryAction": "AUTO_CONFIRM_ORDER",
      "autoTransition": "IDLE"
    },

    "MESSAGE_AWAITING_TEXT": {
      "entryMessage": {
        "type": "text",
        "body": "Please share your question, feedback, or special request. We'll get back to you personally."
      },
      "transitions": [
        { "match": "*", "nextState": "MESSAGE_DONE", "action": "SAVE_FEEDBACK" }
      ]
    },

    "MESSAGE_DONE": {
      "entryMessage": {
        "type": "text",
        "body": "Thank you for writing to us. We've received your message and will get back to you soon."
      },
      "autoTransition": "IDLE"
    }

  }
}
